:443 {
  tls /etc/caddy/certificates/localhost.pem /etc/caddy/certificates/localhost-key.pem
  encode gzip zstd

  @api_docs path /docs* /redoc* /openapi.json
  handle @api_docs {
    reverse_proxy backend:8000
  }

  @api path /api/*
  handle @api {
    reverse_proxy backend:8000
  }

  handle {
    reverse_proxy frontend:3000
  }
}

:80 {
  redir https://{host}{uri}
}
