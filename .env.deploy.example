# Copy to .env.deploy for single-host LAN deployment.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=powergold
DATABASE_URL=postgresql+psycopg2://postgres:change_me@postgres:5432/powergold

SECRET_KEY=change_me
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change_me

TZ=Asia/Manila
NEXT_PUBLIC_API_URL=http://backend:8000
LAN_HOSTNAME=powergold.home.arpa
CORS_ALLOW_ORIGINS=https://powergold.home.arpa
SWAGGER_UI_ENABLED=false
